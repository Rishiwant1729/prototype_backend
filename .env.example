PORT=3000

# MySQL connection (used by Prisma via DATABASE_URL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=university_sports

# JWT
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h

# Prisma Database URL
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/university_sports"

